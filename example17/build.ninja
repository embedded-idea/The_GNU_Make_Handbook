#Possible, but more manual.
#Ninja is usually generated, not handwritten, for this kind of config management.
cc = gcc
mode = debug

cflags = -Wall -Wextra
rule cc_debug
  command = $cc $cflags -O0 -g -DDEBUG -c $in -o $out

rule cc_release
  command = $cc $cflags -O2 -DNDEBUG -c $in -o $out

rule link
  command = $cc $in -o $out

build main.o: cc_debug main.c
build mathlib.o: cc_debug mathlib.c
build app: link main.o mathlib.o

default app

